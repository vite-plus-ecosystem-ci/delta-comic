{
  "name": "@delta-comic/server",
  "private": true,
  "description": "南天门直梯",
  "type": "module",
  "main": "./lib/index.ts",
  "module": "./lib/index.ts",
  "types": "./lib/index.ts",
  "exports": {
    ".": {
      "types": "./lib/index.ts",
      "import": "./lib/index.ts"
    }
  },
  "scripts": {
    "build": "vp build",
    "cf-typegen": "wrangler types",
    "deploy": "vp build && wrangler deploy",
    "dev": "wrangler dev --config wrangler.jsonc",
    "preview": "vp build && vp preview",
    "typecheck": "tsgo -p tsconfig.app.json --noEmit && tsgo -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@delta-comic/server-config": "workspace:",
    "@elysia/eden": "catalog:",
    "ky": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:",
    "@elysiajs/bearer": "catalog:",
    "@elysiajs/cors": "catalog:",
    "@elysiajs/openapi": "catalog:",
    "@sinclair/typebox": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  },
  "peerDependencies": {
    "elysia": "catalog:",
    "openapi-types": "catalog:"
  }
}