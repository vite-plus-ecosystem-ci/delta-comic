{
  "name": "delta-comic",
  "version": "2.2.1",
  "private": true,
  "description": "Per Aspera, Ad Astra",
  "homepage": "https://github.com/delta-comic",
  "bugs": {
    "url": "https://github.com/delta-comic/delta-comic/issues",
