  "repository": {
    "type": "git",
    "url": "https://github.com/delta-comic/delta-comic.git"
  },
  "type": "module",
  "scripts": {
    "check": "vp check",
    "dev": "vp run --filter app dev",
    "lib-build": "vp run -t app#build",
    "release": "node ./script/bootstrap-release-history.mts && vp exec semantic-release",
    "release:dry-run": "node ./script/bootstrap-release-history.mts && vp exec semantic-release --dry-run",
    "set-ver": "node ./script/set-version.mts",
    "tauri": "vp run --filter app tauri",
    "test": "vp test",
    "test:coverage": "vp test run --coverage",
    "typecheck": "vp run -r typecheck",
    "vp:install": "vp install"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "commitlint-plugin-cspell": "catalog:",
    "cspell": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "semantic-release": "^25.0.7",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "badges": [
    {
      "description": "semantic-release: angular",
      "href": "https://github.com/semantic-release/semantic-release",
      "url": "https://img.shields.io/badge/semantic--release-angular-e10079?logo=semantic-release"
    },
    {
