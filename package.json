  },
  "license": "AGPL-3.0-only",
  "author": {
    "name": "wenxig",
    "email": "wenxinguo12@gmail.com",
    "url": "https://github.com/wenxig"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/delta-comic/delta-comic.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vp run --filter app dev",
    "lib-build": "vp run -r build",
    "lint": "vp lint",
    "pub:all": "vp run pub:npm && vp run pub:github",
    "pub:github": "vp run lib-build && pnpm -r publish --no-git-checks --registry https://npm.pkg.github.com/",
    "pub:npm": "vp run lib-build && vp pm publish -r --no-git-checks",
    "set-ver": "node ./script/set-version.mts",
    "tauri": "vp run --filter app tauri",
    "typecheck": "vp run -r typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@iarna/toml": "catalog:",
    "@semantic-release/changelog": "catalog:",
    "@semantic-release/git": "catalog:",
    "@semantic-release/github": "catalog:",
    "@semantic-release/release-notes-generator": "catalog:",
    "@types/iarna__toml": "catalog:",
    "commitlint-plugin-cspell": "catalog:",
    "cspell": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "semantic-release": "catalog:",
    "vite-plus": "catalog:"
  },
  "badges": [
    {
      "description": "semantic-release: angular",
      "href": "https://github.com/semantic-release/semantic-release",
      "url": "https://img.shields.io/badge/semantic--release-angular-e10079?logo=semantic-release"
    },
    {
      "description": "Repo License",
      "href": "https://github.com/delta-comic/delta-comic/blob/main/LICENSE",
      "url": "https://github.com/delta-comic/delta-comic/blob/main/LICENSE"
    },
    {
      "description": "GitHub Downloads (all assets, all releases)",
      "href": "https://github.com/delta-comic/delta-comic/releases/latest",
      "url": "https://img.shields.io/github/downloads/delta-comic/delta-comic/total"
    },
    {
      "description": "Wakatime",
      "href": "https://wakatime.com/projects/delta-comic",
      "url": "https://wakatime.com/badge/user/018cf362-35ff-48f2-af6b-61f09a441de4/project/9f2c18ca-6eec-4e82-8041-5d23c1aba440.svg"
    }
  ],
  "packageManager": "pnpm@11.6.0",
  "readme": "./README.md"
}