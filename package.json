  },
  "repository": {
    "type": "git",
    "url": "https://github.com/delta-comic/delta-comic.git"
  },
  "type": "module",
  "scripts": {
    "build": "echo \"Root skip.\"",
    "dev": "vp run --filter app dev",
    "lint": "vp lint",
    "npm-build": "vp run -r build",
    "set-ver": "node ./script/set-version.mts",
    "tauri": "vp run --filter app tauri",
    "pub:npm": "vp run npm-build && vp pm publish -r --no-git-checks",
    "pub:github": "vp run npm-build && pnpm -r publish --no-git-checks --registry https://npm.pkg.github.com/",
    "pub:all": "vp run npm-build && vp pm publish -r --no-git-checks && pnpm -r publish --no-git-checks --registry https://npm.pkg.github.com/",
    "pub:dry-run": "vp run npm-build && vp pm publish -r --no-git-checks --dry-run"
  },
  "dependencies": {
    "es-toolkit": "catalog:"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@cspell/dict-npm": "^5.2.38",
    "@cspell/dict-rust": "^4.1.2",
    "@iarna/toml": "^3.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/iarna__toml": "^2.0.5",
    "commitlint-plugin-cspell": "^0.9.1",
    "cspell": "^10.0.0",
    "semantic-release": "^25.0.3",
    "vite": "catalog:",
    "vite-plugin-dts": "^5.0.1",
    "vite-plus": "catalog:"
  },
  "badges": [
    {
      "description": "semantic-release: angular",
      "href": "https://github.com/semantic-release/semantic-release",
      "url": "https://img.shields.io/badge/semantic--release-angular-e10079?logo=semantic-release"
    },
    {
      "description": "Repo License",
      "href": "https://github.com/delta-comic/delta-comic/blob/main/LICENSE",
      "url": "https://github.com/delta-comic/delta-comic/blob/main/LICENSE"
    },
    {
      "description": "GitHub Downloads (all assets, all releases)",
      "href": "https://github.com/delta-comic/delta-comic/releases/latest",
      "url": "https://img.shields.io/github/downloads/delta-comic/delta-comic/total"
    },
    {
      "description": "Wakatime",
      "href": "https://wakatime.com/projects/delta-comic",
      "url": "https://wakatime.com/badge/user/018cf362-35ff-48f2-af6b-61f09a441de4/project/9f2c18ca-6eec-4e82-8041-5d23c1aba440.svg"
    }
  ],
  "packageManager": "pnpm@11.2.2",
  "readme": "./README.md"
}