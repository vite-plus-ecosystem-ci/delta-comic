{
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.codeActionsOnSave": { "source.fixAll.oxc": "explicit" },
  "vue.suggest.componentNameCasing": "alwaysPascalCase",
  "vue.suggest.propNameCasing": "alwaysCamelCase",
  "tailwindCSS.classFunctions": ["twMerge", "cn"],
  "tailwindCSS.classAttributes": ["class", "className", "ngClass", "class:list", ":class"],
  "[markdown]": { "editor.defaultFormatter": "DavidAnson.vscode-markdownlint" }
}